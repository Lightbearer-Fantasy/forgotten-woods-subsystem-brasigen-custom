# =============================================================================
# Liste blanche : SEUL le module FoundryVTT est suivi par git.
# Tout est ignoré par défaut ; on ne ré-autorise QUE les fichiers du module.
# Garantit qu'aucun matériel de référence ni secret (.mcp.json, tools/,
# pf2e-hud/, references/, docs/) ne puisse être committé par accident.
# =============================================================================

# 1. Tout ignorer à la racine
/*

# 2. Ré-autoriser le module distribuable
!/module.json
!/scripts/
!/templates/
!/styles/
!/lang/
!/images/
!/assets/
!/packs/
!/README.md
!/LICENSE

# 3. Ré-autoriser le scaffolding projet / tests
!/.gitignore
!/package.json
!/package-lock.json
!/vitest.config.js
!/tests/

# Source des compendiums du module (le binaire packs/effects/ reste ignoré, build au release)
!/packs/
/packs/*
!/packs/_source/
!/packs/_source/**

# Pipeline de build/release versionné (UNIQUEMENT ces 2 scripts ; le reste de
# tools/ — dont mcp-image-server/ — reste ignoré). Aucun secret en dur : le token
# GitHub vient de l'env (GITHUB_TOKEN/GH_TOKEN) ou du credential git.
!/tools/
/tools/*
!/tools/build-packs.mjs
!/tools/release.mjs

# 4. Garde-fous : ces éléments restent ignorés en toutes circonstances
node_modules/
.mcp.json
.env
*.env
*.key
*-key.json
sa-key.json
secrets.json
